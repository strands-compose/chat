# Alembic config now ships inside the package; point the CLI at it explicitly.
ALEMBIC_INI := "src/strands_compose_chat/alembic.ini"

# apply all pending database migrations
[group('db')]
migrate:
    uv run alembic -c {{ALEMBIC_INI}} upgrade head

# create a new autogenerated migration: just revision "message"
[group('db')]
revision message rev_id="":
    uv run alembic -c {{ALEMBIC_INI}} revision --autogenerate -m "{{message}}" {{ if rev_id == "" { "" } else { "--rev-id " + rev_id } }}
