APP_ENV=dev
SESSION_SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=<strong password>
AUTH_REGISTRATION_ENABLED=true

OIDC_PROVIDERS=["entra"]
OIDC_REDIRECT_URI=https://your-domain.com/auth/callback

OIDC_ENTRA_DISPLAY_NAME=Microsoft Entra
OIDC_ENTRA_DISCOVERY_URL=https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
OIDC_ENTRA_CLIENT_ID=<app-registration-client-id>
OIDC_ENTRA_CLIENT_SECRET=<client-secret-from-azure-portal>
